<settings xmlns="http://maven.apache.org/SETTINGS/1.0.0"
  xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
  xsi:schemaLocation="http://maven.apache.org/SETTINGS/1.0.0
                      http://maven.apache.org/xsd/settings-1.0.0.xsd">
    <servers>
        <server>
            <id>snapshots</id>
            <username>nx-deployer</username>
            <password>${env.NEXUS_PASSWORD}</password>
        </server>
        <server>
            <id>releases</id>
            <username>nx-deployer</username>
            <password>${env.NEXUS_PASSWORD}</password>
        </server>
        <server>
            <id>harbor.toolsstg.acerta.io</id>
            <username>robot$harbor-cicd</username>
            <password>${env.HARBOR_PASSWORD}</password>
        </server>
    </servers>
    <profiles>
        <profile>
            <id>nexus</id>
            <repositories>
                <repository>
                    <id>snapshots</id>
                    <releases>
                        <enabled>false</enabled>
                    </releases>
                    <snapshots>
                        <enabled>true</enabled>
                    </snapshots>
                    <url>https://nexus.stg.acerta.io/repository/maven-public</url>
                </repository>
                <repository>
                    <id>releases</id>
                    <releases>
                        <enabled>true</enabled>
                    </releases>
                    <snapshots>
                        <enabled>false</enabled>
                    </snapshots>
                    <url>https://nexus.prd.acerta.io/repository/maven-public</url>
                </repository>
            </repositories>
            <pluginRepositories>
                <pluginRepository>
                    <id>snapshots</id>
                    <releases>
                        <enabled>false</enabled>
                    </releases>
                    <snapshots/>
                    <url>https://nexus.stg.acerta.io/repository/maven-public</url>
                </pluginRepository>
                <pluginRepository>
                    <id>releases</id>
                    <releases/>
                    <snapshots>
                        <enabled>false</enabled>
                    </snapshots>
                    <url>https://nexus.prd.acerta.io/repository/maven-public</url>
                </pluginRepository>
            </pluginRepositories>
        </profile>
    </profiles>
    <activeProfiles>
        <activeProfile>nexus</activeProfile>
    </activeProfiles>
</settings>
